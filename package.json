{
  "name": "kai-ai",
  "version": "1.0.0",
  "description": "AI coding assistant with persistent memory, background agents, and tool use",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kai": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/web/public && cp -r src/web/public dist/web/public && rm -rf dist/agents/builtin-workflows && mkdir -p dist/agents/builtin-workflows && cp src/agents/builtin-workflows/*.yaml dist/agents/builtin-workflows/ && rm -rf dist/skills/builtins && mkdir -p dist/skills/builtins && cp -r src/skills/builtins/* dist/skills/builtins/ && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "npm run build && node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "coding",
    "agents",
    "openrouter",
    "llm",
    "assistant"
  ],
  "author": "Tim Moreton",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmoreton/kai"
  },
  "homepage": "https://github.com/tmoreton/kai#readme",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "gpt-tokenizer": "^2.9.0",
    "hono": "^4.12.9",
    "mammoth": "^1.12.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "node-cron": "^4.2.1",
    "node-notifier": "^10.0.1",
    "openai": "^6.33.0",
    "playwright": "^1.59.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
