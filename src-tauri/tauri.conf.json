{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kai",
  "version": "1.1.3",
  "identifier": "com.kai.desktop",
  "build": {
    "frontendDist": "http://localhost:3141",
    "devUrl": "http://localhost:3141",
    "beforeDevCommand": "npm run dev -- server --port 3141",
    "beforeBuildCommand": "node /Users/tmoreton/Code/kai/scripts/tauri-build.cjs"
  },
  "app": {
    "windows": [
      {
        "title": "Kai",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon-512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/node": "node",
      "resources/dist": "dist",
      "resources/package.json": "package.json",
      "resources/packages": "packages",
      "resources/node_modules": "node_modules"
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "signingIdentity": "Developer ID Application: Tim Moreton (GVXC5FQ2RP)"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
