# Required: OpenRouter API key (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (default: moonshotai/kimi-k2.5)
# Fallback: qwen/qwen3-235b-a22b | Image gen: google/gemini-2.5-flash-image
MODEL_ID=moonshotai/kimi-k2.5

# Optional: Web search via Tavily (https://tavily.com)
TAVILY_API_KEY=

# Optional: YouTube Data API v3 key (for YouTube agent features)
YOUTUBE_API_KEY=
