# Required: Fireworks API key for Kimi K2.5 Turbo (https://fireworks.ai)
FIREWORKS_API_KEY=fw_your-key-here

# Required: OpenRouter API key for image generation (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Web search via Tavily (https://tavily.com)
TAVILY_API_KEY=

# Optional: YouTube Data API v3 key (for YouTube agent features)
YOUTUBE_API_KEY=

# Optional: Twitter/X API OAuth 2.0 credentials (https://developer.x.com)
# From X Developer Portal → your app → "Keys and Tokens":
# 1. Copy Client ID and Client Secret from "OAuth 2.0 Keys" section
# 2. Click "Generate" to create an access token for your account
X_CLIENT_ID=your_oauth2_client_id
X_CLIENT_SECRET=your_oauth2_client_secret
X_ACCESS_TOKEN=your_oauth2_access_token
# Note: Free tier = 500 posts/month. Search requires Basic tier ($100/month).

# Optional: Reddit API credentials (https://www.reddit.com/prefs/apps)
# 1. Create a "script" app at reddit.com/prefs/apps
# 2. Copy Client ID (under app name) and Client Secret (labeled "secret")
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
# Optional: Custom user agent (defaults to KaiResearch/1.0)
# REDDIT_USER_AGENT="KaiResearch/1.0 by u/your_username"
